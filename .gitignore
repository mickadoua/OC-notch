# Build artifacts
build/
OC-Notch/build/
*.zip

# Temporary / downloaded tools
tmp/

# Xcode (generated by xcodegen)
*.xcodeproj/
*.xcuserstate
xcuserdata/
DerivedData/

# Generated icon (source is in Assets.xcassets)
/AppIcon.png

# macOS
.DS_Store

# Local signing config (contains developer identity & team ID)
local.mk

# Purge script config (contains PII for history rewrite)
scripts/purge-config.sh

# Environment / secrets
.env
.env.*
.env.local

# Certificates & keys
*.p12
*.p8
*.pem
*.cer
*.key
*.mobileprovision

# Sparkle EdDSA private key (if exported from Keychain)
# The PUBLIC key (SUPublicEDKey in Info.plist) is safe to commit — it ships with the app.
# The PRIVATE key must NEVER be committed. It lives in your macOS Keychain.
sparkle_private_key
*.sparkle_private_key

# Firebase / Google
GoogleService-Info.plist
google-services.json

# Xcode local config
*.xcconfig
!Shared.xcconfig

# opencode
.sisyphus/*
